---
import Layout from "@/layouts/Layout.astro";
import { ArrowLeft, Home } from "lucide-react";
---

<Layout>
  <main>
    <section
      class="flex min-h-screen items-center px-4 py-32 sm:px-8 md:px-24"
    >
      <div class="mx-auto flex max-w-[1400px] flex-col gap-10">
        <div class="border-border mb-2 border-b pb-8">
          <p
            class="text-muted-foreground mb-3 font-mono text-xs tracking-[0.3em] uppercase"
          >
            ~/portfolio/404
          </p>
          <h1 class="text-foreground mb-3 text-4xl font-bold md:text-5xl">
            Page not found
          </h1>
          <p class="text-muted-foreground max-w-xl text-sm md:text-base">
            The route you requested does not exist, or it may have moved.
          </p>
        </div>

        <div class="flex flex-wrap gap-2">
          <a
            href="/"
            class="bg-foreground text-background inline-flex h-10 items-center justify-center gap-2 rounded-md px-4 text-sm font-medium transition-opacity hover:opacity-85"
          >
            <Home className="h-4 w-4" />
            Home
          </a>
          <a
            href="/projects"
            class="border-border text-foreground hover:border-foreground/40 inline-flex h-10 items-center justify-center gap-2 rounded-md border px-4 text-sm font-medium transition-colors"
          >
            <ArrowLeft className="h-4 w-4" />
            Projects
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
