---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import {
  ApiError,
  createProjectFromRequest,
  deleteProjectFromRequest,
  getProjects,
  getStacks,
  updateProjectFromRequest,
} from "@/lib/api/client";
import {
  ProjectInputSchema,
  type ProjectInput,
  type ProjectWithStack,
} from "@/lib/api/schema";
import { ArrowLeft, Plus, Save, Trash2 } from "lucide-react";

type GroupedProject = Omit<ProjectWithStack, "StackID" | "StackName"> & {
  stacks: Array<{ ID: number; Name: string }>;
};

function groupProjects(projects: ProjectWithStack[]) {
  const grouped = new Map<number, GroupedProject>();

  for (const project of projects) {
    const existing = grouped.get(project.ID);

    if (existing) {
      existing.stacks.push({
        ID: project.StackID,
        Name: project.StackName,
      });
      continue;
    }

    const { StackID, StackName, ...rest } = project;
    grouped.set(project.ID, {
      ...rest,
      stacks: [{ ID: StackID, Name: StackName }],
    });
  }

  return Array.from(grouped.values());
}

function getString(formData: FormData, key: string) {
  const value = formData.get(key);
  return typeof value === "string" ? value.trim() : "";
}

function getProjectInput(formData: FormData): ProjectInput {
  const demo = getString(formData, "demo").trim();

  return ProjectInputSchema.parse({
    title: getString(formData, "title"),
    description: getString(formData, "description"),
    featured: formData.get("featured") === "on",
    github: getString(formData, "github"),
    demo: demo.length > 0 ? demo : undefined,
    stack_ids: formData
      .getAll("stack_ids")
      .map(Number)
      .filter((id) => Number.isInteger(id) && id > 0),
  });
}

let errorMessage = "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");
    const projectId = Number(formData.get("projectId"));

    if (action === "create") {
      await createProjectFromRequest(Astro.request, getProjectInput(formData));
    }

    if (action === "update") {
      await updateProjectFromRequest(
        Astro.request,
        projectId,
        getProjectInput(formData),
      );
    }

    if (action === "delete") {
      await deleteProjectFromRequest(Astro.request, projectId);
    }

    return Astro.redirect("/crm/projects", 303);
  } catch (error) {
    errorMessage =
      error instanceof ApiError
        ? error.message
        : "Could not save project. Check the form and try again.";
  }
}

const [projectsResponse, stacksResponse] = await Promise.all([
  getProjects(),
  getStacks(),
]);
const projects = groupProjects(projectsResponse.body);
const stacks = stacksResponse.body;
---

<Layout>
  <main>
    <section class="px-4 pt-32 pb-20 sm:px-8 md:px-24">
      <div class="mx-auto flex max-w-[1400px] flex-col gap-8">
        <a
          href="/crm"
          class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2 font-mono text-xs transition-colors"
        >
          <ArrowLeft className="h-3.5 w-3.5" />
          cd ../crm
        </a>

        <div class="border-border border-b pb-8">
          <p
            class="text-muted-foreground mb-3 font-mono text-xs tracking-[0.3em] uppercase"
          >
            ~/portfolio/crm/projects
          </p>
          <h1 class="text-foreground mb-3 text-4xl font-bold md:text-5xl">
            Projects
          </h1>
          <p class="text-muted-foreground max-w-xl text-sm md:text-base">
            Manage project entries, links, featured status, and stack labels.
          </p>
        </div>

        {
          errorMessage && (
            <p class="border-destructive/40 bg-destructive/10 text-destructive rounded-md border px-3 py-2 text-sm">
              {errorMessage}
            </p>
          )
        }

        <form
          method="post"
          class="border-border bg-card grid gap-4 rounded-xl border p-5 lg:grid-cols-2"
        >
          <input type="hidden" name="action" value="create" />
          <label class="flex flex-col gap-2">
            <span class="text-foreground font-mono text-xs">title</span>
            <input
              name="title"
              required
              maxlength="255"
              placeholder="Project title"
              class="border-input bg-background text-foreground placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-ring/50 h-10 rounded-md border px-3 text-sm outline-none focus-visible:ring-3"
            />
          </label>
          <label class="flex flex-col gap-2">
            <span class="text-foreground font-mono text-xs">github</span>
            <input
              name="github"
              type="url"
              required
              placeholder="https://github.com/example/repo"
              class="border-input bg-background text-foreground placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-ring/50 h-10 rounded-md border px-3 text-sm outline-none focus-visible:ring-3"
            />
          </label>
          <label class="flex flex-col gap-2 lg:col-span-2">
            <span class="text-foreground font-mono text-xs">description</span>
            <textarea
              name="description"
              required
              rows="3"
              placeholder="Project description"
              class="border-input bg-background text-foreground placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-ring/50 rounded-md border px-3 py-2 text-sm outline-none focus-visible:ring-3"
            ></textarea>
          </label>
          <label class="flex flex-col gap-2">
            <span class="text-foreground font-mono text-xs">demo</span>
            <input
              name="demo"
              type="url"
              placeholder="https://example.com"
              class="border-input bg-background text-foreground placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-ring/50 h-10 rounded-md border px-3 text-sm outline-none focus-visible:ring-3"
            />
          </label>
          <label class="flex items-center gap-2 self-end">
            <input
              name="featured"
              type="checkbox"
              class="border-input bg-background h-4 w-4 rounded"
            />
            <span class="text-foreground font-mono text-xs">featured</span>
          </label>
          <fieldset class="flex flex-col gap-2 lg:col-span-2">
            <legend class="text-foreground mb-2 font-mono text-xs">
              stacks
            </legend>
            <div class="flex flex-wrap gap-2">
              {
                stacks.map((stack) => (
                  <label class="border-border bg-background/70 text-foreground/80 inline-flex items-center gap-2 rounded-md border px-2 py-1 font-mono text-xs">
                    <input name="stack_ids" type="checkbox" value={stack.ID} />
                    {stack.Name}
                  </label>
                ))
              }
            </div>
          </fieldset>
          <button
            type="submit"
            class="bg-foreground text-background inline-flex h-10 items-center justify-center gap-2 rounded-md px-4 text-sm font-medium transition-opacity hover:opacity-85 lg:col-span-2"
          >
            <Plus className="h-4 w-4" />
            Add project
          </button>
        </form>

        <div class="flex flex-col gap-5">
          {
            projects.map((project) => (
              <form
                method="post"
                class="border-border bg-card grid gap-4 rounded-xl border p-5 lg:grid-cols-2"
              >
                <input type="hidden" name="projectId" value={project.ID} />
                <div class="text-muted-foreground font-mono text-xs lg:col-span-2">
                  #{project.ID} / {project.CreatedAt}
                </div>
                <label class="flex flex-col gap-2">
                  <span class="text-foreground font-mono text-xs">title</span>
                  <input
                    name="title"
                    required
                    maxlength="255"
                    value={project.Title}
                    class="border-input bg-background text-foreground focus-visible:border-ring focus-visible:ring-ring/50 h-10 rounded-md border px-3 text-sm outline-none focus-visible:ring-3"
                  />
                </label>
                <label class="flex flex-col gap-2">
                  <span class="text-foreground font-mono text-xs">github</span>
                  <input
                    name="github"
                    type="url"
                    required
                    value={project.Github}
                    class="border-input bg-background text-foreground focus-visible:border-ring focus-visible:ring-ring/50 h-10 rounded-md border px-3 text-sm outline-none focus-visible:ring-3"
                  />
                </label>
                <label class="flex flex-col gap-2 lg:col-span-2">
                  <span class="text-foreground font-mono text-xs">
                    description
                  </span>
                  <textarea
                    name="description"
                    required
                    rows="3"
                    class="border-input bg-background text-foreground focus-visible:border-ring focus-visible:ring-ring/50 rounded-md border px-3 py-2 text-sm outline-none focus-visible:ring-3"
                  >{project.Description.trim()}</textarea>
                </label>
                <label class="flex flex-col gap-2">
                  <span class="text-foreground font-mono text-xs">demo</span>
                  <input
                    name="demo"
                    type="url"
                    value={project.Demo.Valid ? project.Demo.String : ""}
                    class="border-input bg-background text-foreground focus-visible:border-ring focus-visible:ring-ring/50 h-10 rounded-md border px-3 text-sm outline-none focus-visible:ring-3"
                  />
                </label>
                <label class="flex items-center gap-2 self-end">
                  <input
                    name="featured"
                    type="checkbox"
                    checked={project.Featured}
                    class="border-input bg-background h-4 w-4 rounded"
                  />
                  <span class="text-foreground font-mono text-xs">
                    featured
                  </span>
                </label>
                <fieldset class="flex flex-col gap-2 lg:col-span-2">
                  <legend class="text-foreground mb-2 font-mono text-xs">
                    stacks
                  </legend>
                  <div class="flex flex-wrap gap-2">
                    {stacks.map((stack) => (
                      <label class="border-border bg-background/70 text-foreground/80 inline-flex items-center gap-2 rounded-md border px-2 py-1 font-mono text-xs">
                        <input
                          name="stack_ids"
                          type="checkbox"
                          value={stack.ID}
                          checked={project.stacks.some(
                            (projectStack) => projectStack.ID === stack.ID,
                          )}
                        />
                        {stack.Name}
                      </label>
                    ))}
                  </div>
                </fieldset>
                <div class="flex flex-wrap gap-2 lg:col-span-2">
                  <button
                    type="submit"
                    name="action"
                    value="update"
                    class="border-border text-foreground hover:border-foreground/40 inline-flex h-10 items-center justify-center gap-2 rounded-md border px-4 text-sm font-medium transition-colors"
                  >
                    <Save className="h-4 w-4" />
                    Save
                  </button>
                  <button
                    type="submit"
                    name="action"
                    value="delete"
                    class="border-destructive/40 text-destructive hover:bg-destructive/10 inline-flex h-10 items-center justify-center gap-2 rounded-md border px-4 text-sm font-medium transition-colors"
                  >
                    <Trash2 className="h-4 w-4" />
                    Delete
                  </button>
                </div>
              </form>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
