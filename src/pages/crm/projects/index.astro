---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import {
  Card,
  CardAction,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Textarea } from "@/components/ui/textarea";
import {
  ApiError,
  createProjectFromRequest,
  deleteProjectFromRequest,
  getProjects,
  getStacks,
  updateProjectFromRequest,
} from "@/lib/api/client";
import {
  ProjectInputSchema,
  type ProjectInput,
  type ProjectWithStack,
} from "@/lib/api/schema";
import { ArrowLeft, Link2, Plus, Save, Star, Trash2 } from "lucide-react";
import GitHubIcon from "@/components/icons/github";

const fieldClass = "gap-2";
const labelClass = "font-mono text-xs text-muted-foreground";
const saveButtonClass =
  "hover:border-border hover:bg-primary/10 hover:text-foreground";
const nativeCheckboxClass =
  "border-input bg-background text-primary focus-visible:ring-ring/50 h-4 w-4 rounded accent-primary outline-none focus-visible:ring-3";

type GroupedProject = Omit<ProjectWithStack, "StackID" | "StackName"> & {
  stacks: Array<{ ID: number; Name: string }>;
};

function groupProjects(projects: ProjectWithStack[]) {
  const grouped = new Map<number, GroupedProject>();

  for (const project of projects) {
    const existing = grouped.get(project.ID);

    if (existing) {
      existing.stacks.push({
        ID: project.StackID,
        Name: project.StackName,
      });
      continue;
    }

    const { StackID, StackName, ...rest } = project;
    grouped.set(project.ID, {
      ...rest,
      stacks: [{ ID: StackID, Name: StackName }],
    });
  }

  return Array.from(grouped.values());
}

function getString(formData: FormData, key: string) {
  const value = formData.get(key);
  return typeof value === "string" ? value.trim() : "";
}

function getProjectInput(formData: FormData): ProjectInput {
  const demo = getString(formData, "demo").trim();

  return ProjectInputSchema.parse({
    title: getString(formData, "title"),
    description: getString(formData, "description"),
    featured: formData.get("featured") === "on",
    github: getString(formData, "github"),
    demo: demo.length > 0 ? demo : undefined,
    stack_ids: formData
      .getAll("stack_ids")
      .map(Number)
      .filter((id) => Number.isInteger(id) && id > 0),
  });
}

let errorMessage = "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");
    const projectId = Number(formData.get("projectId"));

    if (action === "create") {
      await createProjectFromRequest(Astro.request, getProjectInput(formData));
    }

    if (action === "update") {
      await updateProjectFromRequest(
        Astro.request,
        projectId,
        getProjectInput(formData),
      );
    }

    if (action === "delete") {
      await deleteProjectFromRequest(Astro.request, projectId);
    }

    return Astro.redirect("/crm/projects", 303);
  } catch (error) {
    errorMessage =
      error instanceof ApiError
        ? error.message
        : "Could not save project. Check the form and try again.";
  }
}

const [projectsResponse, stacksResponse] = await Promise.all([
  getProjects(),
  getStacks(),
]);
const projects = groupProjects(projectsResponse.body);
const stacks = stacksResponse.body;
---

<Layout robots="noindex, nofollow">
  <main>
    <section class="px-4 pt-32 pb-20 sm:px-8 md:px-24">
      <div class="mx-auto flex max-w-[1400px] flex-col gap-8">
        <a
          href="/crm"
          class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2 font-mono text-xs transition-colors"
        >
          <ArrowLeft className="h-3.5 w-3.5" />
          cd ../crm
        </a>

        <div class="border-border border-b pb-8">
          <p
            class="text-muted-foreground mb-3 font-mono text-xs tracking-[0.3em] uppercase"
          >
            ~/portfolio/crm/projects
          </p>
          <h1 class="text-foreground mb-3 text-4xl font-bold md:text-5xl">
            Projects
          </h1>
          <p class="text-muted-foreground max-w-xl text-sm md:text-base">
            Manage project entries, links, featured status, and stack labels.
          </p>
        </div>

        {
          errorMessage && (
            <p class="border-destructive/40 bg-destructive/10 text-destructive rounded-md border px-3 py-2 text-sm">
              {errorMessage}
            </p>
          )
        }

        <Card className="gap-0 py-0">
          <CardHeader className="border-border border-b py-5">
            <CardTitle>Add Project</CardTitle>
            <CardDescription>
              Create a portfolio project with links and stack labels.
            </CardDescription>
          </CardHeader>
          <CardContent className="p-5">
            <form method="post" class="grid gap-5 lg:grid-cols-2">
              <input type="hidden" name="action" value="create" />
              <Label className={`flex flex-col ${fieldClass}`}>
                <span class={labelClass}>title</span>
                <Input
                  name="title"
                  required
                  placeholder="Project title"
                  className="h-10"
                />
              </Label>
              <Label className={`flex flex-col ${fieldClass}`}>
                <span class={labelClass}>github</span>
                <Input
                  name="github"
                  type="url"
                  required
                  placeholder="https://github.com/example/repo"
                  className="h-10"
                />
              </Label>
              <Label className={`flex flex-col lg:col-span-2 ${fieldClass}`}>
                <span class={labelClass}>description</span>
                <Textarea
                  name="description"
                  required
                  rows={3}
                  placeholder="Project description"
                  className="min-h-24"
                />
              </Label>
              <Label className={`flex flex-col ${fieldClass}`}>
                <span class={labelClass}>demo</span>
                <Input
                  name="demo"
                  type="url"
                  placeholder="https://example.com"
                  className="h-10"
                />
              </Label>
              <Label
                className="border-border bg-background/40 flex h-10 items-center gap-2 self-end rounded-md border px-3"
              >
                <input
                  name="featured"
                  type="checkbox"
                  class={nativeCheckboxClass}
                />
                <span class={labelClass}>featured</span>
              </Label>
              <fieldset class="flex flex-col gap-3 lg:col-span-2">
                <legend class={labelClass}>stacks</legend>
                <div class="flex flex-wrap gap-2">
                  {
                    stacks.map((stack) => (
                      <label class="border-border bg-background/60 text-foreground/85 hover:border-foreground/30 inline-flex h-8 items-center gap-2 rounded-md border px-3 font-mono text-xs transition-colors">
                        <input
                          name="stack_ids"
                          type="checkbox"
                          value={stack.ID}
                          class={nativeCheckboxClass}
                        />
                        {stack.Name}
                      </label>
                    ))
                  }
                </div>
              </fieldset>
              <Button type="submit" size="lg" className="lg:col-span-2">
                <Plus className="h-4 w-4" />
                Add project
              </Button>
            </form>
          </CardContent>
        </Card>

        <div class="flex flex-col gap-5">
          {
            projects.map((project) => (
              <Card className="gap-0 py-0">
                <form method="post">
                  <input type="hidden" name="projectId" value={project.ID} />
                  <CardHeader className="border-border border-b py-5">
                    <div class="flex min-w-0 flex-col gap-2">
                      <div class="flex flex-wrap items-center gap-2">
                        <CardTitle className="truncate">
                          {project.Title}
                        </CardTitle>
                        {project.Featured && (
                          <Badge variant="secondary" className="gap-1">
                            <Star className="h-3 w-3" />
                            Featured
                          </Badge>
                        )}
                      </div>
                      <CardDescription className="font-mono text-xs">
                        #{project.ID} / {project.CreatedAt}
                      </CardDescription>
                    </div>
                    <CardAction className="flex gap-2">
                      <Button
                        type="submit"
                        name="action"
                        value="update"
                        variant="outline"
                        size="lg"
                        className={saveButtonClass}
                      >
                        <Save className="h-4 w-4" />
                        Save
                      </Button>
                      <Button
                        type="submit"
                        name="action"
                        value="delete"
                        variant="destructive"
                        size="lg"
                      >
                        <Trash2 className="h-4 w-4" />
                        Delete
                      </Button>
                    </CardAction>
                  </CardHeader>
                  <CardContent className="grid gap-5 p-5 lg:grid-cols-2">
                    <Label className={`flex flex-col ${fieldClass}`}>
                      <span class={labelClass}>title</span>
                      <Input
                        name="title"
                        required
                        defaultValue={project.Title}
                        className="h-10"
                      />
                    </Label>
                    <Label className={`flex flex-col ${fieldClass}`}>
                      <span class={labelClass}>
                        <GitHubIcon className="mr-1 inline h-3.5 w-3.5" />
                        github
                      </span>
                      <Input
                        name="github"
                        type="url"
                        required
                        defaultValue={project.Github}
                        className="h-10"
                      />
                    </Label>
                    <Label
                      className={`flex flex-col lg:col-span-2 ${fieldClass}`}
                    >
                      <span class={labelClass}>description</span>
                      <Textarea
                        name="description"
                        required
                        rows={3}
                        defaultValue={project.Description.trim()}
                        className="min-h-24"
                      />
                    </Label>
                    <Label className={`flex flex-col ${fieldClass}`}>
                      <span class={labelClass}>
                        <Link2 className="mr-1 inline h-3.5 w-3.5" />
                        demo
                      </span>
                      <Input
                        name="demo"
                        type="url"
                        defaultValue={
                          project.Demo.Valid ? project.Demo.String : ""
                        }
                        className="h-10"
                      />
                    </Label>
                    <Label className="border-border bg-background/40 flex h-10 items-center gap-2 self-end rounded-md border px-3">
                      <input
                        name="featured"
                        type="checkbox"
                        checked={project.Featured}
                        class={nativeCheckboxClass}
                      />
                      <span class={labelClass}>featured</span>
                    </Label>
                    <fieldset class="flex flex-col gap-3 lg:col-span-2">
                      <legend class={labelClass}>stacks</legend>
                      <div class="flex flex-wrap gap-2">
                        {stacks.map((stack) => (
                          <label class="border-border bg-background/60 text-foreground/85 hover:border-foreground/30 inline-flex h-8 items-center gap-2 rounded-md border px-3 font-mono text-xs transition-colors">
                            <input
                              name="stack_ids"
                              type="checkbox"
                              value={stack.ID}
                              checked={project.stacks.some(
                                (projectStack) => projectStack.ID === stack.ID,
                              )}
                              class={nativeCheckboxClass}
                            />
                            {stack.Name}
                          </label>
                        ))}
                      </div>
                    </fieldset>
                  </CardContent>
                </form>
              </Card>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
