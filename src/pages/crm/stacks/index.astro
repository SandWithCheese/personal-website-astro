---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import { Button } from "@/components/ui/button";
import {
  Card,
  CardAction,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import {
  ApiError,
  createStackFromRequest,
  deleteStackFromRequest,
  getStacks,
  updateStackFromRequest,
} from "@/lib/api/client";
import { StackInputSchema } from "@/lib/api/schema";
import { ArrowLeft, Plus, Save, Trash2 } from "lucide-react";

const fieldClass = "gap-2";
const labelClass = "font-mono text-xs text-muted-foreground";
const saveButtonClass =
  "hover:border-border hover:bg-primary/10 hover:text-foreground";

let errorMessage = "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");
    const stackId = Number(formData.get("stackId"));

    if (action === "create") {
      await createStackFromRequest(
        Astro.request,
        StackInputSchema.parse({
          name: formData.get("name"),
        }),
      );
    }

    if (action === "update") {
      await updateStackFromRequest(
        Astro.request,
        stackId,
        StackInputSchema.parse({
          name: formData.get("name"),
        }),
      );
    }

    if (action === "delete") {
      await deleteStackFromRequest(Astro.request, stackId);
    }

    return Astro.redirect("/crm/stacks", 303);
  } catch (error) {
    errorMessage =
      error instanceof ApiError
        ? error.message
        : "Could not save stack. Check the form and try again.";
  }
}

const stacksResponse = await getStacks();
const stacks = stacksResponse.body;
---

<Layout robots="noindex, nofollow">
  <main>
    <section class="px-4 pt-32 pb-20 sm:px-8 md:px-24">
      <div class="mx-auto flex max-w-[1400px] flex-col gap-8">
        <a
          href="/crm"
          class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2 font-mono text-xs transition-colors"
        >
          <ArrowLeft className="h-3.5 w-3.5" />
          cd ../crm
        </a>

        <div class="border-border border-b pb-8">
          <p
            class="text-muted-foreground mb-3 font-mono text-xs tracking-[0.3em] uppercase"
          >
            ~/portfolio/crm/stacks
          </p>
          <h1 class="text-foreground mb-3 text-4xl font-bold md:text-5xl">
            Stacks
          </h1>
          <p class="text-muted-foreground max-w-xl text-sm md:text-base">
            Manage the stack labels used by portfolio projects.
          </p>
        </div>

        {
          errorMessage && (
            <p class="border-destructive/40 bg-destructive/10 text-destructive rounded-md border px-3 py-2 text-sm">
              {errorMessage}
            </p>
          )
        }

        <Card className="gap-0 py-0">
          <CardHeader className="border-border border-b py-5">
            <CardTitle>Add Stack</CardTitle>
            <CardDescription>
              Create one reusable technology label.
            </CardDescription>
          </CardHeader>
          <CardContent className="p-5">
            <form method="post" class="grid gap-4 md:grid-cols-[1fr_auto]">
              <input type="hidden" name="action" value="create" />
              <Label className={`flex flex-col ${fieldClass}`}>
                <span class={labelClass}>name</span>
                <Input name="name" required placeholder="Go" className="h-10" />
              </Label>
              <Button type="submit" size="lg" className="self-end">
                <Plus className="h-4 w-4" />
                Add stack
              </Button>
            </form>
          </CardContent>
        </Card>

        <div class="grid gap-3">
          {
            stacks.map((stack) => (
              <Card size="sm" className="gap-0 py-0">
                <form
                  method="post"
                  class="grid gap-4 p-4 md:grid-cols-[96px_1fr_auto] md:items-end"
                >
                  <input type="hidden" name="stackId" value={stack.ID} />
                  <div class="text-muted-foreground font-mono text-xs md:pb-3">
                    #{stack.ID}
                  </div>
                  <Label className={`flex flex-col ${fieldClass}`}>
                    <span class={labelClass}>name</span>
                    <Input
                      name="name"
                      required
                      defaultValue={stack.Name}
                      className="h-10"
                    />
                  </Label>
                  <CardAction className="col-auto row-auto flex gap-2 self-end justify-self-start md:justify-self-end">
                    <Button
                      type="submit"
                      name="action"
                      value="update"
                      variant="outline"
                      size="lg"
                      className={saveButtonClass}
                    >
                      <Save className="h-4 w-4" />
                      Save
                    </Button>
                    <Button
                      type="submit"
                      name="action"
                      value="delete"
                      variant="destructive"
                      size="lg"
                    >
                      <Trash2 className="h-4 w-4" />
                      Delete
                    </Button>
                  </CardAction>
                </form>
              </Card>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
