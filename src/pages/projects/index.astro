---
import GitHubIcon from "@/components/icons/github";
import Layout from "@/layouts/Layout.astro";
import { getProjects } from "@/lib/api/client";
import { mapProjectsToUi } from "@/lib/api/projects";
import { ArrowUpRight } from "lucide-react";

const projects = mapProjectsToUi((await getProjects()).body);
---

<Layout>
  <main>
    <section class="px-4 pt-32 pb-20 sm:px-8 md:px-24">
      <div class="mx-auto flex max-w-[1400px] flex-col gap-10">
        <div class="border-border mb-2 border-b pb-8">
          <p
            class="text-muted-foreground mb-3 font-mono text-xs tracking-[0.3em] uppercase"
          >
            ~/portfolio/all-projects
          </p>
          <h1 class="text-foreground mb-3 text-4xl font-bold md:text-5xl">
            All Projects
          </h1>
          <p class="text-muted-foreground max-w-xl text-sm md:text-base">
            An archive of my personal projects, experiments, tools, and things
            built just to learn.
          </p>
        </div>

        <div
          class="grid auto-rows-fr gap-4 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
        >
          {
            projects.map((project) => {
              const primaryLink = project.links.demo ?? project.links.github;

              return (
                <article class="group border-border bg-card hover:border-foreground/40 hover:shadow-foreground/5 flex h-full min-h-[220px] flex-col rounded-xl border p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
                  <div class="mb-2 flex items-start justify-between gap-3">
                    <h2 class="text-foreground text-lg font-bold">
                      <a
                        href={primaryLink}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline-offset-4 group-hover:underline"
                      >
                        {project.title}
                      </a>
                    </h2>
                    <a
                      href={primaryLink}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`Open ${project.title}`}
                    >
                      <ArrowUpRight className="mt-1 h-4 w-4 shrink-0 text-muted-foreground transition-all duration-300 group-hover:-translate-y-1 group-hover:translate-x-1 group-hover:text-foreground" />
                    </a>
                  </div>

                  <p class="text-muted-foreground mb-4 line-clamp-3 flex-1 text-sm leading-relaxed">
                    {project.description}
                  </p>

                  <div class="mb-4 flex flex-wrap gap-1.5">
                    {project.tags.map((tag) => (
                      <span class="border-border/80 bg-background/70 text-foreground/80 group-hover:border-foreground/40 group-hover:text-foreground rounded-md border px-2 py-0.5 font-mono text-[11px] transition-colors">
                        {tag}
                      </span>
                    ))}
                  </div>

                  <div class="border-border flex items-center gap-2 border-t pt-3">
                    {project.links.github && (
                      <a
                        href={project.links.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="border-border text-foreground hover:border-foreground/40 inline-flex items-center gap-1.5 rounded-md border px-2.5 py-1 text-[11px] font-medium transition-colors"
                      >
                        <GitHubIcon className="h-3 w-3 fill-current" />
                        Code
                      </a>
                    )}
                    {project.links.demo && (
                      <a
                        href={project.links.demo}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="bg-foreground text-background inline-flex items-center gap-1.5 rounded-md px-2.5 py-1 text-[11px] font-medium transition-opacity hover:opacity-85"
                      >
                        Live
                        <ArrowUpRight className="h-3 w-3" />
                      </a>
                    )}
                  </div>
                </article>
              );
            })
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
