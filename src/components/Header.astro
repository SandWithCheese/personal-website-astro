---
const pathname = Astro.url.pathname;

const navItems = [
  { href: "/", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/journals", label: "Journals" },
];

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};
---

<header
  id="main-header"
  class:list={[
    "fixed inset-x-0 top-0 z-10 flex w-full justify-center px-10 py-4",
  ]}
>
  <nav
    class="flex justify-center rounded-full border-b border-b-[#525252]/60 bg-[#242424]/75 px-2 py-3 backdrop-blur-lg"
  >
    <ul class="text-muted-foreground flex text-sm">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
              class:list={[
                "px-4 py-2 duration-150 ease-in-out hover:text-[#e5e7eb]",
                isActive(item.href) &&
                  "bg-background/40 rounded-full text-[#e5e7eb]",
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
