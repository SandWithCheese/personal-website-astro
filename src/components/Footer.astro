---
const year = new Date().getFullYear();

const links = [
  { href: "https://github.com/SandWithCheese", label: "GitHub" },
  { href: "https://linkedin.com/in/ahmad-naufal-ramadan", label: "LinkedIn" },
  { href: "https://instagram.com/naufal.rmdn", label: "Instagram" },
  { href: "mailto:naufalahmad022@gmail.com", label: "Email" },
];
---

<footer
  class="border-border/30 text-muted-foreground grid w-full grid-cols-1 items-center gap-4 border-t px-4 py-6 text-center text-xs sm:px-8 md:grid-cols-3 md:px-10"
>
  <div class="hidden md:block"></div>

  <p>&copy; {year} Ahmad Naufal Ramadan. All rights reserved.</p>

  <ul class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 md:justify-end">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            target={link.href.startsWith("mailto:") ? undefined : "_blank"}
            rel={
              link.href.startsWith("mailto:") ? undefined : "noopener noreferrer"
            }
            class="duration-150 ease-in-out hover:text-[#e5e7eb]"
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</footer>
